# ============================================================================
# Adaptive Neuro-Fuzzy Productivity Suite — .gitignore
# Covers: Python backend, Node.js frontend, Chrome extension dev artifacts
# ============================================================================

# ---------------------
# Python
# ---------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
*.manifest
*.spec
pip-log.txt
pip-delete-this-directory.txt
.Python
env/
venv/
.venv/
ENV/
*.virtualenv
.python-version

# pytest / coverage
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/

# mypy / type checkers
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/

# ---------------------
# Node.js / Frontend
# ---------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
.eslintcache
*.tsbuildinfo

# Vite
frontend/dist/
frontend/.vite/

# ---------------------
# SQLite
# ---------------------
*.db
*.sqlite
*.sqlite3

# ---------------------
# IDE / Editor
# ---------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ---------------------
# OS
# ---------------------
*.log
*.pid
*.seed
*.pid.lock

# ---------------------
# Environment variables
# ---------------------
.env
.env.*
!.env.example

# ---------------------
# Chrome Extension dev
# ---------------------
telemetry_extension/*.crx
telemetry_extension/*.pem
telemetry_extension/*.zip
